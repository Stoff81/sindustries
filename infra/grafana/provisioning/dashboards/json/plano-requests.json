{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "LLM Requests / min by Model",
      "description": "Rate of LLM requests proxied through Plano, broken down by model name. Derived from OpenTelemetry trace spans via the spanmetrics connector.",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "req/min",
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "stacking": { "mode": "none" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "60 * sum(rate(traces_span_metrics_calls_total{service_name=\"plano(llm)\"}[$__rate_interval])) by (llm_model)",
          "legendFormat": "{{ llm_model }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Agent Requests / sec by Agent",
      "description": "Rate of agent invocations through the orchestrator, broken down by agent ID. Derived from OpenTelemetry trace spans.",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "req/s",
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "stacking": { "mode": "none" }
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(traces_span_metrics_calls_total{service_name=\"plano(agent)\"}[$__rate_interval])) by (agent_id)",
          "legendFormat": "{{ agent_id }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "LLM Tokens / sec",
      "description": "Token throughput from Plano's native histogram metric.",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "tokens/sec",
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "stacking": { "mode": "none" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(tokens_per_second_sum[$__rate_interval])) / clamp_min(sum(rate(tokens_per_second_count[$__rate_interval])), 1e-9)",
          "legendFormat": "tokens/sec",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Rate-Limited Requests / sec",
      "description": "Rate of requests rejected by Envoy WASM rate limiting. This is a global counter from the llm_gateway filter — no per-model breakdown is available.",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "req/s",
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "stacking": { "mode": "none" }
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(envoy_wasmcustom_ratelimited_rq[$__rate_interval])",
          "legendFormat": "Rate-Limited",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Plano Request Latency p50 / p95 / p99",
      "description": "Latency from spanmetrics: histogram_quantile uses le (seconds on the wire for duration_milliseconds_* metrics) ×1000 → ms. Mean is sum(rate(_sum))/sum(rate(_count)) and is already in ms for traces_span_metrics_duration_milliseconds_* — do not multiply by 1000.",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "ms",
            "drawStyle": "line",
            "fillOpacity": 0,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "stacking": { "mode": "none" }
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(1000 * histogram_quantile(0.50, sum(rate(traces_span_metrics_duration_milliseconds_bucket{service_name=~\"plano.*\"}[$__rate_interval])) by (le, service_name))) or (1000 * histogram_quantile(0.50, sum(rate(traces_span_metrics_duration_seconds_bucket{service_name=~\"plano.*\"}[$__rate_interval])) by (le, service_name))) or (1000 * histogram_quantile(0.50, sum(rate(traces_span_metrics_duration_bucket{service_name=~\"plano.*\"}[$__rate_interval])) by (le, service_name)))",
          "legendFormat": "p50 {{ service_name }}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(1000 * histogram_quantile(0.95, sum(rate(traces_span_metrics_duration_milliseconds_bucket{service_name=~\"plano.*\"}[$__rate_interval])) by (le, service_name))) or (1000 * histogram_quantile(0.95, sum(rate(traces_span_metrics_duration_seconds_bucket{service_name=~\"plano.*\"}[$__rate_interval])) by (le, service_name))) or (1000 * histogram_quantile(0.95, sum(rate(traces_span_metrics_duration_bucket{service_name=~\"plano.*\"}[$__rate_interval])) by (le, service_name)))",
          "legendFormat": "p95 {{ service_name }}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(1000 * histogram_quantile(0.99, sum(rate(traces_span_metrics_duration_milliseconds_bucket{service_name=~\"plano.*\"}[$__rate_interval])) by (le, service_name))) or (1000 * histogram_quantile(0.99, sum(rate(traces_span_metrics_duration_seconds_bucket{service_name=~\"plano.*\"}[$__rate_interval])) by (le, service_name))) or (1000 * histogram_quantile(0.99, sum(rate(traces_span_metrics_duration_bucket{service_name=~\"plano.*\"}[$__rate_interval])) by (le, service_name)))",
          "legendFormat": "p99 {{ service_name }}",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(traces_span_metrics_duration_milliseconds_sum{service_name=~\"plano.*\"}[$__rate_interval])) by (service_name) / sum(rate(traces_span_metrics_duration_milliseconds_count{service_name=~\"plano.*\"}[$__rate_interval])) by (service_name)",
          "legendFormat": "mean {{ service_name }}",
          "refId": "D"
        }
      ]
    },
    {
      "title": "Cumulative Request Count by Model",
      "description": "Total number of LLM requests per model since the collector started.",
      "type": "stat",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic-by-name" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background_gradient",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(traces_span_metrics_calls_total{service_name=\"plano(llm)\"}) by (llm_model)",
          "legendFormat": "{{ llm_model }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Span status errors / sec",
      "description": "Rate of spans with OTEL status ERROR (includes upstream LLM failures and client-side failures such as filter chain / content_guard rejections when Plano marks the span as error). Broken down by Plano service and model when present.",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "err/s",
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "stacking": { "mode": "none" }
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(traces_span_metrics_calls_total{service_name=~\"plano.*\", status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) by (service_name, llm_model)",
          "legendFormat": "{{ service_name }} {{ llm_model }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Errors by HTTP status (4xx/5xx)",
      "description": "Non-success HTTP status on trace spans: legacy http.status_code, stable semconv http.response.status_code, and span ERROR when neither HTTP code dimension is set (covers filter chain 400s that only set span status). Same underlying request can appear in at most one of these series.",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "err/s",
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "stacking": { "mode": "none" }
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(traces_span_metrics_calls_total{service_name=~\"plano.*\", http_status_code=~\"[45]..\"}[$__rate_interval])) by (http_status_code, llm_model)",
          "legendFormat": "http.status_code={{ http_status_code }} {{ llm_model }}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(traces_span_metrics_calls_total{service_name=~\"plano.*\", http_response_status_code=~\"[45]..\"}[$__rate_interval])) by (http_response_status_code, llm_model)",
          "legendFormat": "http.response.status_code={{ http_response_status_code }} {{ llm_model }}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(traces_span_metrics_calls_total{service_name=~\"plano.*\", status_code=\"STATUS_CODE_ERROR\", http_status_code=\"\", http_response_status_code=\"\"}[$__rate_interval])) by (service_name, llm_model)",
          "legendFormat": "span_error (no HTTP code) {{ service_name }} {{ llm_model }}",
          "refId": "C"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["plano", "llm", "observability"],
  "templating": {
